#zmodload zsh/zprof
# =============================================================================
# 1. Environment & Base Paths
# =============================================================================
export MY_DOMAIN_NAME="gachca.com"
export UID=$(id -u)
export GID=$(id -g)

{{- if eq .osid "darwin" }}
export TZ=$(readlink /etc/localtime | sed 's|.*/zoneinfo/||')
{{- else if or (eq .osid "linux-debian") (eq .osid "linux-ubuntu") }}
export TZ=$(timedatectl show -p Timezone --value)
{{- else }}
export TZ=$(readlink /etc/localtime | awk -F'/zoneinfo/' '{print $2}')
{{- end }}

export IP={{ .ip | quote }}

# Base PATH
export PATH="$HOME/.local/bin:$PATH"

{{- if eq .osid "darwin" }}
# Homebrew Base
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"

# 1Password SSH agent
export OP_SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
if [ -S "$OP_SSH_AUTH_SOCK" ]; then
    export SSH_AUTH_SOCK="$OP_SSH_AUTH_SOCK"
fi
{{- end }}

{{- if eq .hostname "mbp" }}
# MBP Specific Paths & Flags
export https_proxy="http://127.0.0.1:6152"
export http_proxy="http://127.0.0.1:6152"
export all_proxy="socks5://127.0.0.1:6153"
export PATH="/opt/homebrew/opt/gnu-sed/libexec/gnubin:/opt/homebrew/opt/curl/bin:$PATH"
export LDFLAGS="-L/opt/homebrew/opt/curl/lib"
export CPPFLAGS="-I/opt/homebrew/opt/curl/include"
export PKG_CONFIG_PATH="/opt/homebrew/opt/curl/lib/pkgconfig"
. "$HOME/.local/share/../bin/env"
{{- end }}

{{- if or (eq .osid "linux-ubuntu") (eq .osid "linux-debian") }}
export N_PREFIX="$HOME/n"
[[ :$PATH: == *":$N_PREFIX/bin:"* ]] || PATH+=":$N_PREFIX/bin"
{{- end }}

# =============================================================================
# 2. Zsh Options & Keybindings
# =============================================================================
setopt AUTO_CD
setopt EXTENDED_GLOB
bindkey '^f' autosuggest-accept

# =============================================================================
# 3. Directory Hashes
# =============================================================================
hash -d conf="$XDG_CONFIG_HOME"
hash -d nv="$XDG_CONFIG_HOME/nvim/"
hash -d ct="$XDG_CONFIG_HOME/containers/"

{{- if eq .osid "darwin" }}
hash -d dld="$HOME/Downloads"
hash -d dev="$HOME/Developer"
hash -d dbx="$HOME/Dropbox"
hash -d sur="$HOME/Library/Mobile Documents/iCloud~com~nssurge~inc/Documents"
{{- end }}

# =============================================================================
# 4. Plugin Management (Znap) & Completions
# =============================================================================
[[ -f $HOME/.znap/zsh-snap/znap.zsh ]] || git clone --depth 1 -- https://github.com/marlonrichert/zsh-snap.git $HOME/.znap/zsh-snap
source $HOME/.znap/zsh-snap/znap.zsh

unset ZSH_AUTOSUGGEST_USE_ASYNC
znap source zsh-users/zsh-autosuggestions
znap source zsh-users/zsh-completions
znap source ael-code/zsh-colored-man-pages

# The NEX engine can misinterpret bracketed-paste terminators over SSH.
ZVM_READKEY_ENGINE=zle
znap source jeffreytse/zsh-vi-mode

# Register these after zsh-vi-mode so its widgets cannot replace them.
autoload -Uz bracketed-paste-magic
zle -N bracketed-paste bracketed-paste-magic
autoload -Uz url-quote-magic
zle -N self-insert url-quote-magic

{{- if eq .osid "darwin" }}
command -v fzf >/dev/null && znap source thirteen37/fzf-brew
{{- end }}

fpath=($HOME/.znap/zsh-completions/src $fpath)
autoload -Uz compinit && compinit

# =============================================================================
# 5. Tool Initializations (Go, Python, Node, Ruby, etc.)
# =============================================================================
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"

{{- if eq .osid "darwin" }}
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_OPTS="--reverse --border"
{{- end }}

{{- if eq .hostname "mbp" }}
# GPG & 1Password
export GPG_TTY=$(tty)
command -v gpgconf >/dev/null && gpgconf --launch gpg-agent
[ -f "$HOME/.config/op/plugins.sh" ] && source "$HOME/.config/op/plugins.sh"

# Development Environments
export GOPATH="$HOME/.go"
export PATH="$PATH:$GOPATH/bin"

export N_PREFIX="$HOME/.n"
export PATH="$N_PREFIX/bin:$PATH"

export PYENV_ROOT="$HOME/.pyenv"
command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"

eval "$(rbenv init - zsh)"
. "$HOME/.cargo/env"

export JENV_ROOT="$HOME/.jenv"
if [ -d "${JENV_ROOT}" ]; then
    export PATH="$JENV_ROOT/bin:$PATH"
    eval "$(jenv init - --no-rehash)"
    (jenv rehash &) 2> /dev/null
fi

[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"
{{- end }}

# =============================================================================
# 6. Aliases & Functions
# =============================================================================
alias cl="clear"
alias tm="tmux"
alias tmn="tmux new"
alias tmk="tmux kill-session -t"
alias nv="nvim"
alias path="print -l $path"
alias cz="chezmoi"
alias czet="chezmoi execute-template"
alias cld="claude"

alias -g ...="../.."
alias -g ....="../../.."
alias -g .....="../../../.."
alias -g ......="../../../../.."

alias dus="du -smh * | sort -nr"
alias lh="ls -d .*"
alias tgz="tar -czf"
alias ugz="tar -xzf"
alias zz="z -"

# Eza
alias l="eza --sort Name"
alias ll="eza --sort Name --long --octal-permissions --hyperlink --total-size"
alias la="eza --sort Name --long --octal-permissions --hyperlink --all"
alias lt="eza --sort Name --long --octal-permissions --hyperlink --tree"
alias lta="eza --sort Name --long --octal-permissions --hyperlink --tree --all"

# Git
alias gl="git log --pretty=format:'%C(yellow)%h%C(reset) - %C(green)%an%C(reset), %C(blue)%ar%C(reset) (%C(magenta)%ad%C(reset)) : %C(red)%s%C(reset)' --date=format:'%Y-%m-%d %H:%M:%S'"

# Docker
alias d="docker"
alias dcu="docker compose up"
alias dcud="docker compose up -d"
alias dcudf="docker compose up -d --force-recreate"
alias dcd="docker compose down"
alias dcp="docker compose pull"

# Ansible
alias asb="ansible"
alias apb="ansible-playbook"

{{- if eq .osid "darwin" }}
# macOS / Homebrew
alias nq="networkQuality"
alias brew="env PATH=\"${PATH/\/Users\/${USER}\/\.pyenv\/shims:/}\" brew"
alias bi="brew install"
alias bd="brew update"
alias bg="brew upgrade"
alias ci="brew install --cask"
alias bui="brew uninstall"
alias cui="brew uninstall --cask"
alias bcu="brew cu"
alias bs="brew search"
alias bl="brew leaves"
alias budg="brew update && brew upgrade"
alias bc="brew cleanup"
alias bdc="brew doctor"
alias binf="brew info"
alias bo="brew outdated"
alias bdp="brew deps"
alias bdpt="brew deps --tree"
{{- end }}

{{- if eq .hostname "mbp" }}
# MBP Specific Aliases
alias enc="gpg -r 8F7941D4 -e"
alias p1p="pass show -c 1Password"
alias lin="lima nerdctl"
alias lil="limactl"
alias clm="colima"
alias dasl="sudo rm -rf /private/var/log/asl/*.asl"
alias ts="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
alias rime="rime-install iDvel/rime-ice:others/recipes/all_dicts"
alias yabairl='launchctl kickstart -k "gui/${UID}/homebrew.mxcl.yabai"'
alias yabairc='nvim ~/.config/yabai/yabairc'
{{- end }}

source $HOME/.zsh_functions

# =============================================================================
# 7. Ghostty, Hostname Template & Prompt (Oh-my-posh)
# =============================================================================
{{- if ne .hostname "mbp" }}
{{ template "hostname" . }}
{{- end }}

if [ -n "${GHOSTTY_RESOURCES_DIR}" ]; then
    builtin source "${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration"
fi

if [ "$TERM_PROGRAM" != "Apple_Terminal" ] && command -v oh-my-posh >/dev/null; then
    eval "$(oh-my-posh init zsh --config ~/.config/ohmyposh/omp.toml)"
fi

# =============================================================================
# 8. Syntax Highlighting (Must be loaded LAST)
# =============================================================================
znap source zdharma-continuum/fast-syntax-highlighting
#zprof
