{{- if or (eq .osid "linux-debian") (eq .osid "linux-ubuntu") -}}
#!/bin/bash

set -euo pipefail

# Keep sudo alive
sudo -v
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

echo "Updating APT package index..."
sudo apt-get update -y

# Fix locale
echo "Checking locale configuration..."
if ! dpkg -l locales &>/dev/null; then
    sudo apt-get install -y locales
fi
if ! grep -q "^en_US.UTF-8" /etc/locale.gen 2>/dev/null; then
    echo "en_US.UTF-8 UTF-8" | sudo tee -a /etc/locale.gen > /dev/null
fi
sudo locale-gen
sudo update-locale LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
echo "Locale set to: $(locale | grep ^LANG)"

# Install general packages
echo "Checking general packages..."
packages=("gpg" "zoxide" "curl" "wget" "net-tools" "zsh" "git" "tmux" "ripgrep" "gcc" "make" "unzip" "xz-utils" "tar" "ca-certificates")
missing_packages=()

for pkg in "${packages[@]}"; do
    if ! dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q "install ok installed"; then
        missing_packages+=("$pkg")
    fi
done

if [ ${#missing_packages[@]} -gt 0 ]; then
    echo "Installing missing packages: ${missing_packages[*]}"
    sudo apt-get install -y "${missing_packages[@]}"
else
    echo "All general packages are already installed."
fi

# Install latest fzf
if ! command -v fzf >/dev/null 2>&1 || ! fzf --version | grep -q -E "0\.(5[3-9]|[6-9][0-9])"; then
    echo "Installing/Updating fzf to a newer version..."
    
    ARCH=$(uname -m)
    if [ "$ARCH" = "x86_64" ]; then FZF_ARCH="amd64"
    elif [ "$ARCH" = "aarch64" ]; then FZF_ARCH="arm64"
    else FZF_ARCH="amd64"; fi

    FZF_URL=$(curl -s https://api.github.com/repos/junegunn/fzf/releases/latest | grep "browser_download_url" | grep "linux_${FZF_ARCH}.tar.gz" | cut -d '"' -f 4)
    
    if [ -n "$FZF_URL" ]; then
        TMP_DIR=$(mktemp -d)
        if curl -fsSL -o "${TMP_DIR}/fzf.tar.gz" "$FZF_URL"; then
            tar xzf "${TMP_DIR}/fzf.tar.gz" -C "${HOME}/.local/bin"
            echo "fzf installed successfully."
        else
            echo "Failed to download fzf." >&2
        fi
        rm -rf "${TMP_DIR}"
    else
        echo "Failed to fetch fzf release URL from GitHub API." >&2
    fi
else
    echo "fzf is already up to date."
fi

# Install Neovim
if ! command -v nvim >/dev/null 2>&1 || [ ! -x "${HOME}/.local/bin/nvim" ]; then
    echo "Neovim is not installed. Fetching stable release..."
    TMP_DIR=$(mktemp -d)
    
    trap 'rm -rf "${TMP_DIR}"' EXIT 

    if curl -fsSL -o "${TMP_DIR}/nvim.tar.gz" "https://github.com/neovim/neovim/releases/download/stable/nvim-linux-x86_64.tar.gz"; then
        mkdir -p "${HOME}/.local"
        tar xzf "${TMP_DIR}/nvim.tar.gz" --strip-components=1 -C "${HOME}/.local"
        echo "Neovim installed successfully."
    else
        echo "Failed to download Neovim. Check your network." >&2
    fi
    
    trap - EXIT
    rm -rf "${TMP_DIR}"
else
    echo "Neovim is already installed."
fi

# Install TPM
if [ ! -d "${HOME}/.config/tmux/plugins/tpm" ]; then
    echo "Installing Tmux Plugin Manager..."
    mkdir -p "${HOME}/.config/tmux/plugins"
    git clone https://github.com/tmux-plugins/tpm "${HOME}/.config/tmux/plugins/tpm"
fi

# Install eza
if ! command -v eza >/dev/null 2>&1; then
    echo "Installing eza..."
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor --yes -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list > /dev/null
    sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
    sudo apt-get update
    sudo apt-get install -y eza
else
    echo "eza is already installed."
fi

# Install Tailscale
if ! command -v tailscale >/dev/null 2>&1; then
    echo "Installing Tailscale..."
    curl -fsSL https://tailscale.com/install.sh | sh
else
    echo "Tailscale is already installed."
fi

# Install Oh My Posh
if ! command -v oh-my-posh >/dev/null 2>&1; then
    echo "Installing Oh My Posh..."
    curl -s https://ohmyposh.dev/install.sh | sudo bash -s -- -d /usr/local/bin
else
    echo "Oh My Posh is already installed."
fi

# Install Docker
{{- if .docker }}
if ! command -v docker >/dev/null 2>&1; then
    echo "Installing Docker..."
    sudo apt-get install -y ca-certificates curl gnupg

    sudo install -m 0755 -d /etc/apt/keyrings
    curl -fsSL "https://download.docker.com/linux/{{ .osid | replace "linux-" "" }}/gpg" | sudo gpg --dearmor --yes -o /etc/apt/keyrings/docker.gpg
    sudo chmod a+r /etc/apt/keyrings/docker.gpg

    . /etc/os-release
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/${ID} ${VERSION_CODENAME} stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

    sudo apt-get update
    sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

    sudo usermod -aG docker "${USER}"
    echo "Docker installed! Please log out and log back in, or run 'su - ${USER}' to apply groups."
else
    echo "Docker is already installed."
fi
{{- end }}

# Change default shell to zsh
ZSH_PATH=$(command -v zsh)
if [ "$SHELL" != "$ZSH_PATH" ]; then
    echo "Changing default shell to zsh..."
    sudo chsh -s "$ZSH_PATH" "${USER}"
fi

echo "Ubuntu/Debian setup complete!"

{{- end -}}
