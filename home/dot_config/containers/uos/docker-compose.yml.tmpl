services:
  init-dirs:
    image: alpine:latest
    container_name: uos-init
    restart: "no"
    volumes:
      - .:/workdir
    command: >
      sh -c "mkdir -p /workdir/data/{persistent,var-log,data,srv,var-lib-unifi,var-lib-mongodb,etc-rabbitmq-ssl} 
      && chown -R ${UID}:${GID} /workdir/data"
  unifi-os-server:
    image: ghcr.io/lemker/unifi-os-server:latest
    container_name: uos
    restart: unless-stopped
    network_mode: host 
    cgroup: host
    cap_add:
      - NET_RAW
      - NET_ADMIN
    tmpfs:
      - /run:exec
      - /run/lock
      - /tmp:exec
      - /var/lib/journal
      - /var/opt/unifi/tmp:size=64m
    environment:
      - UOS_SYSTEM_IP=${IP}
      - TZ=${TZ}
    volumes:
      - /sys/fs/cgroup:/sys/fs/cgroup:rw
      - ./data/persistent:/persistent
      - ./data/var-log:/var/log
      - ./data/data:/data
      - ./data/srv:/srv
      - ./data/var-lib-unifi:/var/lib/unifi
      - ./data/var-lib-mongodb:/var/lib/mongodb
      - ./data/etc-rabbitmq-ssl:/etc/rabbitmq/ssl
