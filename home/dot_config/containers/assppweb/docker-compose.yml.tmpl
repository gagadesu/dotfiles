services:
  assppweb:
    image: ghcr.io/lakr233/assppweb:latest
    container_name: assppweb
    restart: always
    ports:
      - '8087:8080'
    environment:
      - DATA_DIR=/data
      - PORT=8080
    volumes:
      - 'data:/data'
    networks:
      - proxy
    labels:
      - "com.centurylinklabs.watchtower.enable=false"
      - "traefik.enable=true"
      - "traefik.http.routers.assppweb.entrypoints=http"
      - "traefik.http.routers.assppweb.rule=Host(`assppweb.${HOSTNAME}.${MY_DOMAIN_NAME}`)"
      - "traefik.http.middlewares.assppweb-https-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.assppweb.middlewares=assppweb-https-redirect"
      - "traefik.http.routers.assppweb-secure.entrypoints=https"
      - "traefik.http.routers.assppweb-secure.rule=Host(`assppweb.${HOSTNAME}.${MY_DOMAIN_NAME}`)"
      - "traefik.http.routers.assppweb-secure.tls=true"
      - "traefik.http.routers.assppweb-secure.service=assppweb"
      - "traefik.http.services.assppweb.loadbalancer.server.port=8080"
      - "traefik.docker.network=proxy"

volumes:
  data:

networks:
  proxy:
    external: true
