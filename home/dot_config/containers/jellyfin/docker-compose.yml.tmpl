services:
  jellyfin:
    {{- if eq .osid "darwin" }}
    image: nyanmisaka/jellyfin:240401-arm64
    {{- end }}
    {{- if ne .osid "darwin" }}
    image: nyanmisaka/jellyfin
    {{- end }}
    container_name: jellyfin
    restart: always
    network_mode: host
    volumes:
      {{- if eq .hostname "media" }}
      - /mnt/media/shares:/media
      {{- end }}
      {{- if eq .hostname "home" }}
      - /mnt/media/porns:/media
      {{- end }}
      - config:/config
      - cache:/cache

volumes:
  config:
  cache:
