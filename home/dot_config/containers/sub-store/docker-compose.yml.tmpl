services:
  sub-store:
    image: xream/sub-store:2.24.19-http-meta
    container_name: sub-store
    restart: unless-stopped

    environment:
      TZ: Asia/Tokyo
      SUB_STORE_FRONTEND_BACKEND_PATH: "${SUB_STORE_BACKEND_PATH:?run deploy.sh from the Mac first}"
      SUB_STORE_BACKEND_SYNC_CRON: "55 23 * * *"
      SUB_STORE_CORS_ALLOWED_ORIGINS: "https://sub-store.vercel.app,http://substore.stash,https://substore.stash"

    ports:
      - "127.0.0.1:13001:3001"

    volumes:
      - ./data:/opt/app/data

    networks:
      - proxy

    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.sub-store.entrypoints=http"
      - "traefik.http.routers.sub-store.rule=Host(`sub-store.${HOSTNAME}.${MY_DOMAIN_NAME}`)"
      - "traefik.http.middlewares.sub-store-https-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.sub-store.middlewares=sub-store-https-redirect"
      - "traefik.http.routers.sub-store-secure.entrypoints=https"
      - "traefik.http.routers.sub-store-secure.rule=Host(`sub-store.${HOSTNAME}.${MY_DOMAIN_NAME}`)"
      - "traefik.http.routers.sub-store-secure.tls=true"
      - "traefik.http.routers.sub-store-secure.service=sub-store"
      - "traefik.http.services.sub-store.loadbalancer.server.port=3001"
      - "traefik.docker.network=proxy"

    healthcheck:
      test:
        - CMD-SHELL
        - >-
          node -e "fetch('http://127.0.0.1:3001'+process.env.SUB_STORE_FRONTEND_BACKEND_PATH+'/api/utils/env').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s

    security_opt:
      - no-new-privileges:true

networks:
  proxy:
    external: true
