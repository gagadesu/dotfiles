# ==========================================
# Global Settings 
# Inherited from the JSON version for better terminal compatibility
# ==========================================
console_title_template = ' {{ "{{ .Folder }}" }} :: {{ "{{if .Root}}" }}Admin{{ "{{end}}" }}'
version = 3
final_space = true
terminal_background = 'p:t-background'

# ==========================================
# Color Palette
# ==========================================
[palette]
  main-bg = '#24283b'
  terminal-red = '#f7768e'
  pistachio-green = '#9ece6a'
  terminal-green = '#73daca'
  terminal-yellow = '#e0af68'
  terminal-blue = '#7aa2f7'
  celeste-blue = '#b4f9f8'
  light-sky-blue = '#7dcfff'
  terminal-white = '#c0caf5'
  white-blue = '#a9b1d6'
  blue-bell = '#9aa5ce'
  pastal-grey = '#cfc9c2'
  terminal-magenta = '#bb9af7'
  blue-black = '#565f89'
  terminal-black = '#414868'
  t-background = 'p:main-bg'

# ==========================================
# Secondary Prompt
# ==========================================
[secondary_prompt]
  template = '➜ '
  foreground = 'p:terminal-blue'
  background = 'transparent'

# ==========================================
# Transient Prompt
# ==========================================
[transient_prompt]
  template = '➜ '
  foreground = 'p:terminal-blue'
  # background = 'p:t-background'

# ==========================================
# Left Prompt Block (Path, Git, Status)
# ==========================================
[[blocks]]
  type = 'prompt'
  alignment = 'left'

{{- if ne .hostname "mbp" }}
  [[blocks.segments]]
    type = 'os'
    style = 'plain'
    foreground = 'p:white-blue'
    template = '{{ "{{ .Icon }}" }} '

  [[blocks.segments]]
    type = 'session'
    style = 'plain'
    foreground = 'p:terminal-green'
    template = '{{ "{{ .UserName }}" }}@{{ "{{ .HostName }}" }} '
{{- end }}

  [[blocks.segments]]
    type = 'text'
    style = 'plain'
    background = 'transparent'
    foreground = 'p:terminal-blue'
    template = '➜ '

  [[blocks.segments]]
    type = 'path'
    style = 'plain'
    foreground = 'p:terminal-magenta'
    template = '<b>{{ "{{ .Path }}" }}</b> <p:light-sky-blue>⚡</>'
    [blocks.segments.properties]
      style = 'folder'

  [[blocks.segments]]
    type = 'git'
    style = 'plain'
    foreground = 'p:light-sky-blue'
    foreground_templates = [
      '{{ "{{ if or (.Working.Changed) (.Staging.Changed) }}" }}p:terminal-red{{ "{{ end }}" }}',
      '{{ "{{ if and (gt .Ahead 0) (gt .Behind 0)}}" }}p:light-sky-blue {{ "{{ end }}" }}',
      '{{ "{{ if gt .Ahead 0 }}" }}p:terminal-blue{{ "{{ end }}" }}',
      '{{ "{{ if gt .Behind 0 }}" }}p:celeste-blue{{ "{{ end }}" }}'
    ]
    template = '({{ "{{ .HEAD}}" }})'
    [blocks.segments.properties]
      fetch_status = true
      branch_icon = ' '

  [[blocks.segments]]
    type = 'status'
    style = 'plain'
    foreground = 'p:terminal-red'
    template = ' '

# ==========================================
# Right Prompt Block
# ==========================================
[[blocks]]
  type = 'prompt'
  alignment = 'right'
  overflow = 'hide'

  # Node.js
  [[blocks.segments]]
    type = 'node'
    style = 'plain'
    foreground = 'p:pistachio-green'
    template = '📦 {{ "{{ .Full }}" }} '

  # Python
  [[blocks.segments]]
    type = 'python'
    style = 'plain'
    foreground = 'p:terminal-yellow'
    template = '🐍 {{ "{{ .Full }}" }} '
    [blocks.segments.properties]
      python_binary = 'python3'
      display_mode = 'context'

  # C / C++
  [[blocks.segments]]
    type = 'c'
    style = 'plain'
    foreground = 'p:terminal-blue'
    template = '⚙️ {{ "{{ .Full }}" }} '

  # Java
  [[blocks.segments]]
    type = 'java'
    style = 'plain'
    foreground = 'p:terminal-red'
    template = '☕ {{ "{{ .Full }}" }} '

  # Go
  [[blocks.segments]]
    type = 'go'
    style = 'plain'
    foreground = 'p:light-sky-blue'
    template = '🐹 {{ "{{ .Full }}" }} '

  # Lua
  [[blocks.segments]]
    type = 'lua'
    style = 'plain'
    foreground = 'p:terminal-blue'
    template = '🌙 {{ "{{ .Full }}" }} '

  # Rust
  [[blocks.segments]]
    type = 'rust'
    style = 'plain'
    foreground = 'p:terminal-red'
    template = '🦀 {{ "{{ .Full }}" }} '

  # Git
  [[blocks.segments]]
    type = 'command'
    style = 'plain'
    foreground = 'p:white-blue'
    [blocks.segments.properties]
      command = 'git log --pretty=format:%cr -1 || date +%H:%M:%S'
      shell = 'bash'

# ==========================================
# Newline Prompt Block
# ==========================================
[[blocks]]
  type = 'prompt'
  alignment = 'left'
  newline = true

  [[blocks.segments]]
    type = 'text'
    style = 'plain'
    foreground = 'p:pistachio-green'
    template = '▶'
